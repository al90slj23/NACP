# NACP 环境变量配置

# ─── 数据库 ───────────────────────────────────────────────────────────────────
SQL_DSN=nacp:nacp_pass_2026@tcp(nacp-mysql:3306)/nacp?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_ROOT_PASSWORD=nacp_root_2026
MYSQL_DATABASE=nacp
MYSQL_USER=nacp
MYSQL_PASSWORD=nacp_pass_2026

# ─── 基础配置 ─────────────────────────────────────────────────────────────────
SESSION_SECRET=your_session_secret_here
TZ=Asia/Shanghai

# ─── 重试配置 ─────────────────────────────────────────────────────────────────
# RetryTimes: 跨优先级重试次数（0=不跨优先级，但同渠道重试和预热仍然生效）
# RETRY_TIMES=2

# ─── 渠道测试 ─────────────────────────────────────────────────────────────────
# CHANNEL_TEST_FREQUENCY=10

# ─── Redis（可选）─────────────────────────────────────────────────────────────
# REDIS_CONN_STRING=redis://localhost:6379

# ─── 内存缓存 ─────────────────────────────────────────────────────────────────
MEMORY_CACHE_ENABLED=true
SYNC_FREQUENCY=60
